{
  "name": "Trossen Stationary AI",
  "config": {
    "robot_name": "trossen_stationary_ai",

    "hardware": {
      "arms": {
        "leader_left": {
          "ip_address":   "192.168.1.3",
          "model":        "wxai_v0",
          "end_effector": "wxai_v0_leader"
        },
        "leader_right": {
          "ip_address":   "192.168.1.2",
          "model":        "wxai_v0",
          "end_effector": "wxai_v0_leader"
        },
        "follower_left": {
          "ip_address":   "192.168.1.5",
          "model":        "wxai_v0",
          "end_effector": "wxai_v0_follower"
        },
        "follower_right": {
          "ip_address":   "192.168.1.4",
          "model":        "wxai_v0",
          "end_effector": "wxai_v0_follower"
        }
      },
      "cameras": [
        {
          "id":            "camera_high",
          "serial_number": "128422271347",
          "width":         640,
          "height":        480,
          "fps":           30,
          "use_depth":     false
        },
        {
          "id":            "camera_low",
          "serial_number": "218622270304",
          "width":         640,
          "height":        480,
          "fps":           30,
          "use_depth":     false
        },
        {
          "id":            "camera_left_wrist",
          "serial_number": "218622274938",
          "width":         640,
          "height":        480,
          "fps":           30,
          "use_depth":     false
        },
        {
          "id":            "camera_right_wrist",
          "serial_number": "130322272628",
          "width":         640,
          "height":        480,
          "fps":           30,
          "use_depth":     false
        }
      ]
    },

    "producers": [
      {
        "type":            "trossen_arm",
        "hardware_id":     "leader_left",
        "stream_id":       "leader_left",
        "poll_rate_hz":    30.0,
        "use_device_time": false
      },
      {
        "type":            "trossen_arm",
        "hardware_id":     "leader_right",
        "stream_id":       "leader_right",
        "poll_rate_hz":    30.0,
        "use_device_time": false
      },
      {
        "type":            "trossen_arm",
        "hardware_id":     "follower_left",
        "stream_id":       "follower_left",
        "poll_rate_hz":    30.0,
        "use_device_time": false
      },
      {
        "type":            "trossen_arm",
        "hardware_id":     "follower_right",
        "stream_id":       "follower_right",
        "poll_rate_hz":    30.0,
        "use_device_time": false
      },
      {
        "type":            "realsense_camera",
        "hardware_id":     "camera_high",
        "stream_id":       "camera_high",
        "poll_rate_hz":    30.0,
        "encoding":        "bgr8",
        "use_device_time": true
      },
      {
        "type":            "realsense_camera",
        "hardware_id":     "camera_low",
        "stream_id":       "camera_low",
        "poll_rate_hz":    30.0,
        "encoding":        "bgr8",
        "use_device_time": true
      },
      {
        "type":            "realsense_camera",
        "hardware_id":     "camera_left_wrist",
        "stream_id":       "camera_left_wrist",
        "poll_rate_hz":    30.0,
        "encoding":        "bgr8",
        "use_device_time": true
      },
      {
        "type":            "realsense_camera",
        "hardware_id":     "camera_right_wrist",
        "stream_id":       "camera_right_wrist",
        "poll_rate_hz":    30.0,
        "encoding":        "bgr8",
        "use_device_time": true
      }
    ],

    "teleop": {
      "enabled": true,
      "rate_hz": 1000.0,
      "pairs": [
        { "leader": "leader_left",  "follower": "follower_left"  },
        { "leader": "leader_right", "follower": "follower_right" }
      ]
    },

    "backend": {
      "root":             "~/.trossen_sdk",
      "dataset_id":       "stationary_dataset",
      "compression":      "",
      "chunk_size_bytes": 4194304
    },

    "session": {
      "max_duration":  20.0,
      "max_episodes":  5,
      "backend_type":  "trossen_mcap",
      "reset_duration": 5.0
    }
  }
}
